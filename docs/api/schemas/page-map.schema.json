{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tigges/FLOW_WIZARD/main/docs/api/schemas/page-map.schema.json",
  "title": "PageMap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pageMapId",
    "sessionId",
    "version",
    "status",
    "pages",
    "updatedAt"
  ],
  "properties": {
    "pageMapId": {
      "type": "string",
      "pattern": "^pm_[a-zA-Z0-9_-]{6,}$"
    },
    "sessionId": {
      "type": "string",
      "pattern": "^ses_[A-Za-z0-9_-]{8,}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "validated",
        "locked"
      ]
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pageId",
          "fileId",
          "index",
          "role",
          "included"
        ],
        "properties": {
          "pageId": {
            "type": "string"
          },
          "fileId": {
            "type": "string"
          },
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "cover",
              "body",
              "appendix",
              "reference",
              "ignore"
            ]
          },
          "included": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
