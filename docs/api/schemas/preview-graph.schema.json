{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tigges/FLOW_WIZARD/main/docs/api/schemas/preview-graph.schema.json",
  "title": "PreviewGraph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "revision",
    "nodes",
    "edges",
    "generatedAt"
  ],
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "page",
            "component",
            "asset",
            "binding"
          ]
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "ready",
            "warning",
            "error"
          ]
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "relationship"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "contains",
            "references",
            "derived-from"
          ]
        }
      }
    }
  }
}
