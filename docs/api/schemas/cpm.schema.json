{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tigges/FLOW_WIZARD/main/docs/api/schemas/cpm.schema.json",
  "title": "CPM",
  "type": "object",
  "required": [
    "sessionId",
    "revision",
    "nodes",
    "edges",
    "lastPatchedAt"
  ],
  "properties": {
    "sessionId": {
      "type": "string"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "lastPatchedAt": {
      "type": "string",
      "format": "date-time"
    },
    "patchAudit": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patchOp"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "type",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "page",
            "section",
            "component",
            "asset"
          ]
        },
        "name": {
          "type": "string"
        },
        "props": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "edge": {
      "type": "object",
      "required": [
        "from",
        "to",
        "relation"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "relation": {
          "type": "string"
        }
      }
    },
    "patchOp": {
      "type": "object",
      "required": [
        "op",
        "path"
      ],
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "add",
            "remove",
            "replace",
            "move",
            "copy",
            "test"
          ]
        },
        "path": {
          "type": "string"
        },
        "from": {
          "type": "string"
        },
        "value": {}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "op": {
                "const": "move"
              }
            }
          },
          "then": {
            "required": [
              "from"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "const": "copy"
              }
            }
          },
          "then": {
            "required": [
              "from"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "op": {
                "enum": [
                  "add",
                  "replace",
                  "test"
                ]
              }
            }
          },
          "then": {
            "required": [
              "value"
            ]
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
