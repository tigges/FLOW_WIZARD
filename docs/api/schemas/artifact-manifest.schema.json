{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tigges/FLOW_WIZARD/main/docs/api/schemas/artifact-manifest.schema.json",
  "title": "ArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "compileJobId",
    "status",
    "artifacts",
    "createdAt"
  ],
  "properties": {
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "compileJobId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "canceled"
      ]
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactId",
          "kind",
          "fileName",
          "sizeBytes",
          "checksumSha256",
          "downloadUrl"
        ],
        "properties": {
          "artifactId": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "package",
              "manifest",
              "report",
              "log"
            ]
          },
          "fileName": {
            "type": "string",
            "minLength": 1
          },
          "sizeBytes": {
            "type": "integer",
            "minimum": 0
          },
          "checksumSha256": {
            "type": "string",
            "minLength": 64
          },
          "downloadUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
